// Module: string-utils.fl
// 문자열 유틸리티 함수들

export fn concat(a: string, b: string) -> string {
  return a + b;
}

export fn toUpperCase(s: string) -> string {
  // 향후 구현 (현재는 기본 동작)
  return s;
}

export fn toLowerCase(s: string) -> string {
  // 향후 구현 (현재는 기본 동작)
  return s;
}

export fn length(s: string) -> number {
  return strlen(s);
}
