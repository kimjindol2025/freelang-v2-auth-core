// Main module test
// import/export 기능 테스트

import { add, multiply, PI } from "./math";
import { concat, length } from "./string-utils";

fn main() -> void {
  // Test 1: Named imports from math module
  let result1: number = add(5, 3);
  println(result1);  // Expected: 8

  // Test 2: Multiple imports
  let result2: number = multiply(5, 3);
  println(result2);  // Expected: 15

  // Test 3: Exported constant
  println(PI);  // Expected: 3.14159

  // Test 4: String utils
  let text: string = concat("Hello", " World");
  println(text);  // Expected: "Hello World"

  // Test 5: String length
  let len: number = length("hello");
  println(len);  // Expected: 5

  return;
}
