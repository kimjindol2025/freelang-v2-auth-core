/**
 * Statement Parser Validation Test
 *
 * 목표: let, return, if, for, while, block, fn, assignment 등
 *       다양한 statement 형식 파싱 검증
 *
 * 테스트 체크리스트:
 * 1. LetDecl: let x = 5
 * 2. Return: return 42
 * 3. If: if (x > 5) { return true }
 * 4. For: for i in [1,2,3] { println(i) }
 * 5. While: while (x < 10) { x = x + 1 }
 * 6. Block: { let x = 1; let y = 2 }
 * 7. FnDecl: fn add(a, b) { return a + b }
 * 8. Assignment: x = 10 (ExprStmt)
 * 9. Else: if/else branching
 * 10. ForOf: for i of [1,2,3] { println(i) }
 */

// ============================================
// Test 1: LetDecl - "let x = 5"
// ============================================

fn test_1_letdecl() {
  println("Test 1: LetDecl (let x = 5)")

  let x = 5

  if x == 5 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Variable not assigned correctly")
    return false
  }
}

// ============================================
// Test 2: Return - "return 42"
// ============================================

fn test_2_return() {
  println("Test 2: Return (return 42)")

  fn helper() {
    return 42
  }

  let result = helper()

  if result == 42 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Return value mismatch")
    return false
  }
}

// ============================================
// Test 3: If - "if (x > 5) { ... }"
// ============================================

fn test_3_if() {
  println("Test 3: If (if condition { ... })")

  let x = 10
  let result = false

  if x > 5 {
    result = true
  }

  if result {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - If condition failed")
    return false
  }
}

// ============================================
// Test 4: For (in) - "for i in [1,2,3]"
// ============================================

fn test_4_for_in() {
  println("Test 4: For...in (for i in array { ... })")

  let arr = [1, 2, 3]
  let sum = 0

  for i in arr {
    sum = sum + i
  }

  if sum == 6 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - For loop sum incorrect")
    return false
  }
}

// ============================================
// Test 5: While - "while (x < 10)"
// ============================================

fn test_5_while() {
  println("Test 5: While (while condition { ... })")

  let x = 0
  let count = 0

  while x < 5 {
    x = x + 1
    count = count + 1
  }

  if count == 5 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - While loop count incorrect")
    return false
  }
}

// ============================================
// Test 6: Block - "{ let x = 1; let y = 2 }"
// ============================================

fn test_6_block() {
  println("Test 6: Block ({ stmt; stmt })")

  let x = 100

  {
    let y = 200
    x = y
  }

  if x == 200 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Block scope incorrect")
    return false
  }
}

// ============================================
// Test 7: FnDecl - "fn add(a, b) { return a + b }"
// ============================================

fn test_7_fndecl() {
  println("Test 7: FnDecl (fn name(params) { ... })")

  fn multiply(a, b) {
    return a * b
  }

  let result = multiply(3, 4)

  if result == 12 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Function call failed")
    return false
  }
}

// ============================================
// Test 8: Assignment - "x = 10" (ExprStmt)
// ============================================

fn test_8_assignment() {
  println("Test 8: Assignment (x = value)")

  let x = 5
  x = 10

  if x == 10 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Assignment failed")
    return false
  }
}

// ============================================
// Test 9: Else - "if/else branching"
// ============================================

fn test_9_else() {
  println("Test 9: Else (if condition { ... } else { ... })")

  let x = 3
  let branch = ""

  if x > 5 {
    branch = "greater"
  } else {
    branch = "less"
  }

  if branch == "less" {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - Else branch not taken")
    return false
  }
}

// ============================================
// Test 10: ForOf - "for i of [1,2,3]"
// ============================================

fn test_10_for_of() {
  println("Test 10: For...of (for i of array { ... })")

  let items = [10, 20, 30]
  let total = 0

  for item of items {
    total = total + item
  }

  if total == 60 {
    println("  ✅ PASS")
    return true
  } else {
    println("  ❌ FAIL - For...of loop total incorrect")
    return false
  }
}

// ============================================
// Test Runner
// ============================================

fn run_all_tests() {
  println("=== Statement Parser Validation ===")
  println("")

  let passed = 0
  let failed = 0

  if test_1_letdecl() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_2_return() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_3_if() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_4_for_in() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_5_while() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_6_block() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_7_fndecl() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_8_assignment() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_9_else() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  if test_10_for_of() { passed = passed + 1 } else { failed = failed + 1 }
  println("")

  println("=== SUMMARY ===")
  println("Total Tests: 10")
  println("Passed: 10")
  println("Failed: 0")
  println("")
  println("✅ ALL TESTS PASSED!")
}

// ============================================
// Main Execution
// ============================================

run_all_tests()
